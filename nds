local function criarBotao(nome, posY, key)
	local btnOpt = Instance.new("TextButton")
	btnOpt.Size = UDim2.new(0.9, 0, 0, 32)
	btnOpt.Position = UDim2.new(0.05, 0, 0, posY)
	btnOpt.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
	btnOpt.Text = nome .. ": OFF"
	btnOpt.TextColor3 = Color3.fromRGB(255, 200, 0)
	btnOpt.Font = Enum.Font.Arcade
	btnOpt.TextSize = 14
	btnOpt.Parent = frame
	
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btnOpt
	
	btnOpt.MouseEnter:Connect(function()
		tweenService:Create(btnOpt, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(50, 50, 60)}):Play()
	end)
	btnOpt.MouseLeave:Connect(function()
		tweenService:Create(btnOpt, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(30, 30, 35)}):Play()
	end)
	
	btnOpt.MouseButton1Click:Connect(function()
		settings[key] = not settings[key]
		btnOpt.Text = nome .. ": " .. (settings[key] and "ON" or "OFF")
		btnOpt.TextColor3 = settings[key] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 200, 0)
	end)
end

