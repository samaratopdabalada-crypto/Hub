local function animateColor(text)
	local colors = {
		Color3.fromRGB(255, 100, 150),
		Color3.fromRGB(255, 150, 100),
		Color3.fromRGB(100, 200, 255),
		Color3.fromRGB(150, 255, 100),
	}
	local i = 1
	local function cycle()
		tweenService:Create(text, TweenInfo.new(0.5), {TextColor3 = colors[i]}):Play()
		i = i % #colors + 1
	end
	cycle()
	task.spawn(function()
		while text.Parent do
			task.wait(0.6)
			cycle()
		end
	end)
end
