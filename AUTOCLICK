local cursorActive = false
local clickActive = false
local draggingCursor = false
local clickLoop = nil

local function clickAt(x, y)
    local VirtualInput = game:GetService("VirtualInputManager")
    VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
    VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

cursor.InputBegan:Connect(function(input)
    if cursorActive then
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingCursor = true
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingCursor and cursorActive then
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            cursor.Position = UDim2.new(0, input.Position.X - 30, 0, input.Position.Y - 30)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingCursor = false
    end
end)

btnCursor.MouseButton1Click:Connect(function()
    cursorActive = not cursorActive
    cursor.Visible = cursorActive
    if cursorActive then
        btnCursor.BackgroundColor3 = Color3.fromRGB(200, 100, 100)
        btnCursor.Text = "CURSOR ON"
        status.Text = "DRAG THE RED CIRCLE"
        status.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        btnCursor.BackgroundColor3 = Color3.fromRGB(80, 100, 180)
        btnCursor.Text = "ENABLE CURSOR"
        status.Text = "OFF"
        status.TextColor3 = Color3.fromRGB(150, 150, 150)
        if clickActive then
            clickActive = false
            btnClick.BackgroundColor3 = Color3.fromRGB(80, 160, 80)
            btnClick.Text = "START"
            if clickLoop then clickLoop:Disconnect() end
        end
    end
end)

btnClick.MouseButton1Click:Connect(function()
    if not cursorActive then
        status.Text = "ENABLE CURSOR FIRST"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    clickActive = not clickActive
    
    if clickActive then
        btnClick.BackgroundColor3 = Color3.fromRGB(200, 100, 100)
        btnClick.Text = "STOP"
        status.Text = "CLICKING 60X/SEC"
        status.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        clickLoop = RunService.Heartbeat:Connect(function()
            if clickActive and cursor.Visible then
                local x = cursor.AbsolutePosition.X + 30
                local y = cursor.AbsolutePosition.Y + 30
                clickAt(x, y)
            end
        end)
    else
        btnClick.BackgroundColor3 = Color3.fromRGB(80, 160, 80)
        btnClick.Text = "START"
        status.Text = "STOPPED"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        if clickLoop then
            clickLoop:Disconnect()
            clickLoop = nil
        end
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    if clickLoop then clickLoop:Disconnect() end
    screenGui:Destroy()
end)

local draggingFrame = false
local dragStart = nil
local frameStartPos = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingFrame = true
        dragStart = input.Position
        frameStartPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingFrame then
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingFrame = false
    end
end)
