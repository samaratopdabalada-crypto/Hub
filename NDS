runService.Stepped:Connect(function()
	if settings.nc and player.Character then
		for _, v in pairs(player.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

runService.Heartbeat:Connect(function()
	pcall(function()
		if player.Character then
			local root = player.Character:FindFirstChild("HumanoidRootPart")
			local hum = player.Character:FindFirstChildOfClass("Humanoid")
			
			if hum then
				if settings.g then
					hum.Health = 100
					hum:SetStateEnabled(15, false)
				end
				if settings.as then
					hum.Sit = false
				end
				if hum:GetState() == Enum.HumanoidStateType.Dead then
					hum:ChangeState(11)
				end
			end
			
			if root then
				if settings.af and not settings.f then
					if root.AssemblyLinearVelocity.Magnitude > 60 or root.AssemblyAngularVelocity.Magnitude > 60 then
						root.AssemblyLinearVelocity = Vector3.zero
						root.AssemblyAngularVelocity = Vector3.zero
					end
				end
				if settings.f then
					local vel = root.AssemblyLinearVelocity
					root.AssemblyLinearVelocity = vel * 1000 + Vector3.new(0, 8000, 0)
					runService.RenderStepped:Wait()
					root.AssemblyLinearVelocity = vel
				end
			end
			
			for _, v in pairs(player.Character:GetDescendants()) do
				if v:IsA("TouchTransmitter") then
					if v.Parent and not (v.Parent.Name:find("Leg") or v.Parent.Name:find("Foot")) then
						v:Destroy()
					end
				end
				if settings.ab and (v:IsA("JointInstance") or v:IsA("WeldConstraint")) then
					local p0, p1 = v.Part0, v.Part1
					if (p0 and not p0:IsDescendantOf(player.Character)) or (p1 and not p1:IsDescendantOf(player.Character)) then
						v:Destroy()
					end
				end
			end
		end
	end)
end)
